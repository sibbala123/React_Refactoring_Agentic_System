  "primary_snippet": {
    "content": "import { Loader2 } from 'lucide-react'\n\nimport { Progress } from './progress'\n\n/**\n * A component to display a progress bar with a message and an optional action button. Meant to be rendered in toasts\n * like so\n *  toast.loading(\n *    <ToastProgress\n *      progress={0}\n *      message={`Downloading files...`}\n *    />,\n *    { id: toastId, closeButton: false }\n *  )\n */\nexport const SonnerProgress = ({\n  progress,\n  progressPrefix,\n  action,\n  message,\n  description = 'Please do not close the browser',\n}: {\n  progress: number\n  progressPrefix?: string\n  action?: React.ReactNode\n  message: string\n  description?: string\n}) => (\n  <div className=\"flex gap-3 w-full\">\n    <Loader2 className=\"animate-spin text-foreground-muted mt-0.5\" size={16} />\n    <div className=\"flex flex-col gap-2 w-full\">\n      <div className=\"flex w-full justify-between\">\n        <p className=\"text-foreground text-sm\">{message}</p>\n        <p className=\"text-foreground-light text-sm font-mono\">\n          {progressPrefix || ''}\n          {`${Number(progress).toFixed(0)}%`}\n        </p>\n      </div>\n      <Progress value={progress} className=\"w-full\" />\n      <div className=\"flex flex-row gap-2 items-center justify-between\">\n        <small className=\"text-foreground-lighter text-xs\">{description}</small>\n        {action}\n      </div>\n    </div>\n  </div>\n)",
    "end_line": 46,
    "start_line": 1
  },

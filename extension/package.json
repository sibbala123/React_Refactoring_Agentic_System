{
  "name": "react-refactor",
  "displayName": "ReactRefactor",
  "description": "Agentic code smell detection and refactoring for React projects",
  "version": "0.1.0",
  "publisher": "react-refactor-team",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:**/*.tsx",
    "workspaceContains:**/*.jsx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reactRefactor.scanProject",
        "title": "ReactRefactor: Scan Project for Code Smells"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}

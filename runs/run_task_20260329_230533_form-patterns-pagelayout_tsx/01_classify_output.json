render={({ field }) => (\n                      <FormItemLayout\n                        layout=\"flex-row-reverse\"\n                        label=\"Text Input\"\n                        description=\"Single-line text entry for short values\"\n                      >\n                        <FormControl_Shadcn_>\n                          <Input_Shadcn_ {...field} placeholder=\"Enter text\" />\n                        </FormControl_Shadcn_>\n                      </FormItemLayout>\n                    )}\n                  />\n                </CardContent>\n\n                {/* Password Input */}\n                <CardContent>\n                  <FormField_Shadcn_\n                    control={form.control}\n                    name=\"password\"\n                    render={({ field }) => (\n                      <FormItemLayout\n                        layout=\"flex-row-reverse\"\n                        label=\"Password Input\"\n                        description=\"Masked input for secure text entry\"\n                      >\n                        <FormControl_Shadcn_>\n                          <Input_Shadcn_ {...field} type=\"password\" placeholder=\"Enter password\" />\n                        </FormControl_Shadcn_>\n                      </FormItemLayout>\n                    )}\n                  />\n                </CardContent>\n\n                {/* Copyable Input */}\n                <CardContent>\n                  <FormField_Shadcn_\n                    control={form.control}\n                    name=\"apiKey\"\n                    render={() => (\n                      <FormItemLayout\n                        layout=\"flex-row-reverse\"\n                        label=\"Copyable Input\"\n                        description=\"Read-only input with copy-to-clipboard functionality\"\n                      >\n                        <FormControl_Shadcn_>\n                          <Input\n                            copy\n                          
tTab=\"MB\" className=\"w-full\">\n                            <Input_Shadcn_ {...field} type=\"number\" min={5} max={30} />\n                          </PrePostTab>\n                        </FormControl_Shadcn_>\n                      </FormItemLayout>\n                    )}\n                  />\n                </CardContent>\n\n                {/* Textarea */}\n                <CardContent>\n                  <FormField_Shadcn_\n                    control={form.control}\n                    name=\"description\"\n                    render={({ field }) => (\n                      <FormItemLayout\n                        layout=\"flex-row-reverse\"\n                        label=\"Textarea\"\n                        description=\"Multi-line text input for longer content\"\n                      >\n                        <FormControl_Shadcn_>\n                          <Textarea\n                            {...field}\n                            rows={4}\n                            placeholder=\"Enter multi-line text\"\n                            className=\"resize-none\"\n                          />\n                        </FormControl_Shadcn_>\n                      </FormItemLayout>\n                    )}\n                  />\n                </CardContent>\n\n                {/* Icon Upload */}\n                <CardContent>\n                  <FormField_Shadcn_\n                    control={form.control}\n                    name=\"description\"\n                    render={() => (\n                      <FormItemLayout\n                        layout=\"flex-row-reverse\"\n                        label=\"Icon upload\"\n                        description=\"For icons, avatars, or small images with preview\"\n                      >\n                        <FormControl_Shadcn_>\n                          <div className=\"flex gap-4 items-center\">\n                            <button\n                              type=\"button\"\n                  